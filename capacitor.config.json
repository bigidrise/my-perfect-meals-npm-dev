{
  "appId": "com.myperfectmeals.app",
  "appName": "My Perfect Meals",
  "webDir": "client/dist",
  "server": {
    "url": "https://my-perfect-meals-npm-dev.replit.app",
    "cleartext": false
  },
  "ios": {
    "backgroundColor": "#000000",
    "scrollEnabled": false,
    "contentInset": "automatic"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#000000",
      "androidScaleType": "CENTER_CROP",
      "fadeOutDuration": 300,
      "showSpinner": false
    }
  }
}
